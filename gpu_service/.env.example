# Copy to .env before running:  cp .env.example .env

# Required for speaker diarization (Pyannote on Hugging Face)
# 1. Create token: https://huggingface.co/settings/tokens
# 2. Accept model terms:
#    - https://huggingface.co/pyannote/speaker-diarization-3.1
#    - https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxx

# Host port exposed to your laptop
PORT=8000

# Whisper (faster-whisper / CTranslate2)
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Pyannote pipeline
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
